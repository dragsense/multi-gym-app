
# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===========================================

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
APP_NAME=Full-Stack-Template-Prod
APP_URL=https://yourdomain.com
APP_LOGIN_PATH=login
APP_PASSWORD_RESET_PATH=reset-password

# Server Configuration
HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# Security (PRODUCTION - Use strong, unique secrets)
OTP_SECRET=your-super-secure-otp-secret-key-here
COOKIE_SECRET=your-super-secure-cookie-secret-key-here
ENCRYPTION_KEY=your-super-secure-encryption-key-here
ENCRYPTION_ALGORITHM=aes-256-gcm

# CORS & API
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
API_PREFIX=api/v1

# ===========================================
# DATABASE CONFIGURATION (Production)
# ===========================================
DB_HOST=your-postgres-host.com
DB_PORT=5432
DB_USER=your-postgres-user
DB_PASS=your-super-secure-postgres-password
DB_NAME=fullstack_template_prod

# TypeORM Configuration (Production)
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# Database Pool Configuration
DB_POOL_SIZE=20
DB_POOL_MAX=50
DB_POOL_MIN=10
DB_POOL_IDLE=30000
DB_POOL_CONN_TIMEOUT=10000

# Database Mode and Advanced Configuration
DB_MODE=single
DB_DEFAULT_CONNECTION=default
DB_AUTO_REPLICA=true
DB_AUTO_ARCHIVE=true

# Database Health Check Configuration
DB_HEALTH_CHECK_INTERVAL=30000
DB_HEALTH_CHECK_TIMEOUT=5000
DB_HEALTH_CHECK_QUERY=SELECT 1

# Database Retry Configuration
DB_RETRY_MAX_ATTEMPTS=3
DB_RETRY_DELAY=1000
DB_RETRY_BACKOFF_MULTIPLIER=2

# ===========================================
# JWT CONFIGURATION (Production)
# ===========================================
JWT_SECRET=your-super-secure-jwt-secret-key-here
JWT_REFRESH_SECRET=your-super-secure-jwt-refresh-secret-key-here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
REFRESH_TOKEN_CLEANUP_DAYS=30

# ===========================================
# MAILER CONFIGURATION (Production)
# ===========================================
MAIL_FROM=noreply@yourdomain.com
MAIL_ADMIN_EMAIL=admin@yourdomain.com
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USER=your-smtp-user@yourdomain.com
MAIL_PASS=your-smtp-password
MAIL_DKIM_SELECTOR=default
MAIL_DKIM_PRIVATE_KEY_PATH=/etc/ssl/private/dkim.key

# ===========================================
# CACHE CONFIGURATION (Production - Dragonfly/Redis)
# ===========================================
CACHE_HOST=your-dragonfly-host.com
CACHE_PORT=6379
CACHE_PASSWORD=your-dragonfly-password
CACHE_DB=1
CACHE_DEFAULT_TTL=600
CACHE_MAX_ITEMS=10000
CACHE_PREFIX=prod-app
CACHE_ENABLED=true

# ===========================================
# DRAGONFLY CONFIGURATION (Production - Bull Queue)
# ===========================================
DRAGONFLY_HOST=your-dragonfly-host.com
DRAGONFLY_PORT=6379
DRAGONFLY_PASSWORD=your-dragonfly-password
DRAGONFLY_DB=0

# ===========================================
# CLUSTER CONFIGURATION
# ===========================================
CLUSTER_ENABLED=true
CLUSTER_WORKERS=0

# ===========================================
# ACTIVITY LOGS CONFIGURATION
# ===========================================
ACTIVITY_LOGS_ENABLED=true

# ===========================================
# SCALAR API DOCUMENTATION CONFIGURATION
# ===========================================
SCALAR_THEME=purple
SCALAR_TITLE=Customer App Web API
SCALAR_DESCRIPTION=Empower coaches to manage clients, track progress, and deliver results — all in one simple, powerful tool.
SCALAR_SHOW_SIDEBAR=true
SCALAR_HIDE_DOWNLOAD=false
SCALAR_HIDE_TRY_IT=false
SCALAR_LAYOUT=modern


# ===========================================
# MediaMTX – Camera streaming (RTSP → HLS/WebRTC)
# Backend uses: mediamtx.config.ts
# ===========================================

# Backend → MediaMTX (Control API; Docker service name or host)
MEDIAMTX_HOST=mediamtx
MEDIAMTX_API_PORT=9997
# Must match MediaMTx authInternalUsers (user with permission "api"); required when API is called from another host/container
MEDIAMTX_API_USER=admin
MEDIAMTX_API_PASS=admin123

# MediaMTX internal ports (used if backend builds URLs from host; else use public only)
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_RTSP_PORT=8554

# Public URLs returned to frontend (browser must reach these)
MEDIAMTX_PUBLIC_HOST=yourdomain.com
MEDIAMTX_PUBLIC_HLS_PORT=8888
MEDIAMTX_PUBLIC_WEBRTC_PORT=8889

# Optional: MediaMTX path auth (if configured in mediamtx.yml)
MEDIAMTX_USER=
MEDIAMTX_PASS=

# ===========================================
# Push Notifications (VAPID)
# ===========================================
VAPID_PUBLIC_KEY= public key here 
VAPID_PRIVATE_KEY= private key here

